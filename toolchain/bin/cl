#!/bin/bash
# Wrapper: invoke VC++ 4.2 CL.EXE under CrossOver wine.
# Passes cl options through untouched; converts existing-file/dir args to Z:\ windows paths.
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
VC="${VCDIR:-$HERE/vc42}"        # VCDIR env override lets us A/B-test a candidate VC 4.2 build
export WINEDEBUG="${WINEDEBUG:--all}"
export WINEPREFIX="${WINEPREFIX:-$HOME/.wine}"
# Pre-warm a persistent wineserver so back-to-back CL invocations skip the multi-second cold
# start (wineserver otherwise exits ~3s after its last client). Near-instant no-op once one is
# already persistent; uses the same `wineserver` resolved from PATH as the `wine` below.
wineserver -p 2>/dev/null || true
winp(){ printf 'Z:%s' "$(printf '%s' "$1" | sed 's#/#\\#g')"; }
export INCLUDE="$(winp "$VC/INCLUDE");$(winp "$VC/MFC/INCLUDE")"
export LIB="$(winp "$VC/LIB");$(winp "$VC/MFC/LIB")"
args=()
for a in "$@"; do
  if [[ -e "$a" ]]; then
    abs="$(cd "$(dirname "$a")" && pwd)/$(basename "$a")"
    args+=("$(winp "$abs")")
  else
    args+=("$a")
  fi
done
exec wine "$VC/BIN/CL.EXE" "${args[@]}"
