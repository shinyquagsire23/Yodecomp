#!/bin/bash
# Wrapper: invoke VC++ 4.2 LINK.EXE under CrossOver wine (static-MFC linkage).
# Mirrors bin/cl: sets LIB to the VC + MFC lib dirs, converts existing-file args to Z:\ paths.
set -uo pipefail
HERE="$(cd "$(dirname "$0")/.." && pwd)"
VC="$HERE/vc42"
export WINEDEBUG="${WINEDEBUG:--all}"
export WINEPREFIX="${WINEPREFIX:-$HOME/.wine}"
winp(){ printf 'Z:%s' "$(printf '%s' "$1" | sed 's#/#\\#g')"; }
export LIB="$(winp "$VC/LIB");$(winp "$VC/MFC/LIB")"
args=()
for a in "$@"; do
  if [[ -e "$a" ]]; then
    abs="$(cd "$(dirname "$a")" && pwd)/$(basename "$a")"
    args+=("$(winp "$abs")")
  else
    args+=("$a")
  fi
done
exec wine "$VC/BIN/LINK.EXE" "${args[@]}"
